# This .gitignore file should be placed at the root of your Unity project

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Rr]ecordings/
/UserSettings/

# Asset Store tools
/AssetStoreTools*

# Visual Studio / Rider
.vs/
.idea/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# JetBrains Rider
*.DotSettings.user

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Crash reports
sysinfo.txt

# Addressables
/ServerData/

# Android
.gradle/
*.apk
*.aab

# iOS
DerivedData/

# Generated by Unity
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crashlytics
crashlytics-build.properties

# Backup files
*.bak
*.backup
*.old

# Ignore generated documentation
Documentation~

# Ignore package lock if you don't want it tracked
# Packages/packages-lock.json